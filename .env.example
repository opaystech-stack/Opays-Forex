# Variables d'environnement requises pour Forex Ledger
# Copiez ce fichier en `.env` et renseignez vos clés

# ===== Supabase (Obligatoire — configuré dans Vercel pour le front) =====
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anonyme_supabase

# ===== Sélecteur de backend de données (migration Front→Fastify, Lot L0) =====
# Valeurs : 'mock' | 'supabase' | 'api'. Si absent : 'supabase' quand les clés
# Supabase ci-dessus sont présentes, sinon 'mock' (comportement historique).
# VITE_DATA_BACKEND=supabase
# URL de base de l'API Fastify (utilisée quand VITE_DATA_BACKEND=api) :
# VITE_API_URL=https://app.opays.io/api

# ===== URL publique de l'application (recommandé) =====
# Utilisée pour les redirections d'e-mail d'authentification (getAppBaseUrl).
# À défaut, l'app retombe sur window.location.origin.
# VITE_APP_URL=https://app.opays.io

# ===== Google Gemini IA (secret de l'Edge Function Supabase, PAS Vercel) =====
# Définir via : supabase secrets set GEMINI_API_KEY=...
# GEMINI_API_KEY=votre_cle_api_gemini

# ===== WhatsApp (secrets des Edge Functions Supabase, PAS Vercel) =====
# supabase secrets set WHATSAPP_SEND_GATEWAY_URL=... WHATSAPP_API_SECRET=... WEBHOOK_SECRET=...
# WHATSAPP_SEND_GATEWAY_URL=https://votre-passerelle/whatsapp
# WHATSAPP_API_SECRET=secret_passerelle
# WEBHOOK_SECRET=secret_webhook

# ===== Cron des relances (GUC base de données Supabase, PAS Vercel) =====
# À définir en SQL, voir docs/07_Deployment/deployment_runbook.md :
#   ALTER DATABASE postgres SET app.settings.edge_base_url    = 'https://<ref>.supabase.co/functions/v1';
#   ALTER DATABASE postgres SET app.settings.service_role_key = '<service_role_jwt>';

# ===== Backend Fastify (api/) — déploiement autonome Dokploy =====
# Le serveur REFUSE de démarrer si ces secrets sont absents ou laissés à une
# valeur par défaut non sécurisée. Générez des secrets forts : openssl rand -hex 32
# JWT_SECRET=remplacez_par_un_secret_fort_unique
# COOKIE_SECRET=remplacez_par_un_autre_secret_fort_unique
# DATABASE_URL=postgres://utilisateur:motdepasse@host:5432/fox_db
# Liste blanche CORS (origines séparées par des virgules, sans joker) :
# CORS_ORIGIN=https://app.opays.io,https://fox.opays.io
# NODE_ENV=production
# PORT=3001
