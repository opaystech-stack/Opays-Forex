# =============================================================================
# OpaysFox Admin Stack — variables d'environnement (copier en .env)
# NE JAMAIS committer le .env réel (déjà couvert par .gitignore : .env.*)
# =============================================================================

# --- Base PostgreSQL EXISTANTE d'OpaysFox (Dokploy) ---
# Utilisée par Directus (DB_*) ET par Hermes (DATABASE_URL).
DB_HOST=fox-db
DB_PORT=5432
DB_DATABASE=foxdb
DB_USER=fox
DB_PASSWORD=remplacez_moi
DB_SSL=false
DATABASE_URL=postgres://fox:remplacez_moi@fox-db:5432/foxdb

# --- Directus ---
# Générez KEY/SECRET forts : openssl rand -hex 32
DIRECTUS_KEY=remplacez_par_un_uuid_ou_hex
DIRECTUS_SECRET=remplacez_par_un_secret_fort
DIRECTUS_ADMIN_EMAIL=admin@opays.io
DIRECTUS_ADMIN_PASSWORD=changez_ce_mot_de_passe_fort
DIRECTUS_PUBLIC_URL=https://admin.opays.io
DIRECTUS_PORT=8055
ADMIN_CORS_ORIGIN=https://admin.opays.io
COOKIE_SECURE=true

# --- Hermes Agent (planification cron) ---
TZ=Africa/Kinshasa
CRON_ACCOUNTANT=0 22 * * *
CRON_CRM=0 9 * * *
CRON_SECURITY=0 * * * *
CRM_INACTIVITY_DAYS=15

# Bascule de sécurité : 'true' = aucune écriture/envoi réel (recommandé au démarrage).
HERMES_DRY_RUN=true

# --- Intégrations optionnelles ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
WHATSAPP_GATEWAY_URL=
WHATSAPP_API_SECRET=
